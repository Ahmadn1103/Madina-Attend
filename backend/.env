# Google Sheets Configuration
# Option 1: Provide the JSON credentials as a string (recommended for deployment)
# GOOGLE_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Option 2: Provide the path to the JSON credentials file (recommended for local development)
GOOGLE_CREDENTIALS_PATH=./credentials.json.json

# Google Spreadsheet ID
# You can find this in the URL of your Google Sheet:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
SPREADSHEET_ID=1v8VLNp2ZbATm-piPQKdycT6eKm_aiPkzLMykIYR3E0o

# Frontend URL (optional, defaults to http://localhost:3000)
FRONTEND_URL=http://localhost:3000
